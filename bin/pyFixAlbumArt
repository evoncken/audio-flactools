#!/usr/bin/env python3
# Purpose:
#   Scan for "Folder.jpg" album art in FLAC collection. Some streamers
#   (e.g. Bluesound NODE N132) cannot handle images > 600kB.
#
#   This script resizes the Folder.jpg to below 600kB; the original
#   is backed up to Folder-original.jpg

import os
import logging
from pathlib import Path
from typing import Iterator
try:
    from PIL import Image
except ImportError:
    raise SystemExit("Pillow library is required. Install it with: 'pip install pillow' (generic) or 'brew install pillow' (macOS)")

logger = logging.getLogger(__name__)

def scan_and_filter_folder_images(start_path=".", size_threshold: int = 600 * 1024) -> Iterator[Path]:
    """
    Scans current and subdirectories for JPEG files named "Folder.jpg"
    and yields them if their file size exceeds the threshold (default: 600 kB / 614,400 bytes).
   
    Args:
        start_path: Root directory to scan (default: current directory)
    
    Yields:
        File paths that match criteria
    """
    # Recursively scan directories
    for root, dirs, files in os.walk(start_path):
        if "Folder.jpg" in files:
            file_path = os.path.join(root, "Folder.jpg")
            file_size = os.path.getsize(file_path)
            path_obj = Path(file_path)
            
            # Select files exceeding threshold
            if file_size > size_threshold:
                logger.info(f"  ✓ Selected ({file_size / 1024:.2f} kB): {path_obj}")
                yield path_obj


def reduce_folder_image_size(image_path: Path, size_threshold: int = 600 * 1024, reduction_factor: float = 0.99) -> Path:
    """
    Reduce the resolution of a Folder.jpg image until the file size is below the threshold.
    The original image is renamed to Folder-original.jpg and the resized image is saved back to Folder.jpg.
    """
    if image_path.name != "Folder.jpg":
        raise ValueError("reduce_folder_image_size only supports 'Folder.jpg' images")

    if not image_path.exists():
        raise FileNotFoundError(f"File not found: {image_path}")

    original_path = image_path.with_name("Folder-original.jpg")
    if original_path.exists():
        logger.warning("Backup already exists, not overwriting: %s", original_path)
        source_path = image_path
    else:
        logger.warning("Creating backup: %s", original_path)
        image_path.rename(original_path)
        source_path = original_path

    with Image.open(source_path) as image:
        if image.mode not in ("RGB", "L"):
            image = image.convert("RGB")

        width, height = image.size

        # First attempt: try optimizing with the original dimensions to see if it reduces file size
        resized_image = image.resize((width, height), Image.LANCZOS)
        resized_image.save(image_path, format="JPEG", quality=95, optimize=True)
        current_size = image_path.stat().st_size
        if current_size <= size_threshold:
            logger.info("  ✓ Optimized JPEG only, maintain (%d x %d) -> %.2f kB", width, height, current_size / 1024)
        else:
            logger.info("  ✓ Need to reduce dimensions (%d x %d) -> %.2f kB", width, height, current_size / 1024)
            while True:
                width = max(1, int(width * reduction_factor))
                height = max(1, int(height * reduction_factor))
                resized_image = image.resize((width, height), Image.LANCZOS)
                resized_image.save(image_path, format="JPEG", quality=95, optimize=True)
                current_size = image_path.stat().st_size
                logger.info("  ✓ Trying (%d x %d) -> %.2f kB", width, height, current_size / 1024)

                if current_size <= size_threshold:
                    logger.info("  ✓ Reduced to (%d x %d) -> %.2f kB", width, height, current_size / 1024)
                    break

                image = resized_image

    return image_path


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO, format="%(message)s")

    threshold_kB=600

    print(f"Scanning for Folder.jpg files exceeding {threshold_kB} kB ...")
    selected_files = list(scan_and_filter_folder_images(size_threshold=threshold_kB * 1024))
    print("-"*50)

    print(f"Total files selected: {len(selected_files)}")
    for file in selected_files:
        logger.debug("  - %s", file)

    if len(selected_files) > 0:
        print(f"Reducing file sizes of Folder.jpg files exceeding {threshold_kB} kB...\n")
        for file in selected_files:
            try:
                reduce_folder_image_size(file, size_threshold=threshold_kB * 1024)
            except Exception as error:
                logger.error("Failed to reduce %s: %s", file, error)
    else:
        print("Nothing to do.")

