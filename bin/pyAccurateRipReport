#!/usr/bin/env python3
# Purpose:
#   Parse FLAC file metadata for tracks ripped with dBpoweramp CD Ripper
#
#   Definitions and Conventions:
#     Each "Album" consists of 1 or more "Discs" (CDs)
#     Each "Disc" consists of 1 or more "Tracks"
#
#   Track metadata may contain AccurateRipResult in VORBIS_COMMENT block
#     AccurateRipResult can be "Accurate", "Inaccurate", or "Not in database"
#     This same comment line may contain "Secure: Yes" rip status as well as
#     an optional AccurateRip confidence value in the format "(confidence NNN)"
#     where NNN is an integer confidence value (higher is better).
#     Metadata presence depends on C2 pointers being enabled during ripping
#
#   Quality assessment for Tracks:
#     Track with AccurateRip status "Accurate" is considered 'perfect', regardless of "Secure" status.
#     Track with "Secure: Yes" status is 'good', even if AccurateRip status "Inaccurate" or "Not in database"
#     Track with neither Accurate nor Secure status is 'unknown' - need to verify by listening to rip
#
#   Quality assessment for Discs:
#     Disc with all tracks Accurate is considered 'perfect'
#     Disc with all tracks Accurate or Secure is considered 'good'
#     Disc with any track that is neither Accurate nor Secure is considered 'needs verification'
#
#   Quality assessment for Albums:
#     Album with all discs Accurate is considered 'perfect'
#     Album with all discs Accurate or Secure is considered 'good'
#     Album with any disc that is neither Accurate nor Secure is considered 'needs verification'
#
#   Data structures:
#     AlbumMetadata: dataclass containing all relevant metadata fields for a single album (derived from TrackMetadata)
#     TrackMetadata: dataclass containing all relevant metadata fields for a single track
#     disc_collection[artist][album] = list of TrackMetadata for each track on that album


import argparse
import logging
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Iterator

logger = logging.getLogger(__name__)


@dataclass
class TrackMetadata:
    album_artist: str | None
    album: str | None
    artist: str | None
    date: str | None
    disc_number: int | 1
    disc_total: int | 1
    encoded_by: str | None
    encoder: str | None
    genre: str | None
    track_name: str | None
    track_number: int | None
    track_total: int | None
    accuraterip: str | None
    secure: str | None
    ar_confidence: int | 0


def parse_arguments() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Report AccurateRip / Secure status for FLAC tracks"
    )
    parser.add_argument(
        "-d",
        "--debug",
        action="store_true",
        help="Debugging output",
    )
    parser.add_argument(
        "-a",
        "--report-accurate",
        action="store_true",
        help="Show fully accurate albums",
    )
    parser.add_argument(
        "--report-all",
        action="store_true",
        help="Show all albums",
    )
    parser.add_argument(
        "-s",
        "--report-secure",
        action="store_true",
        help="Show secure tracks",
    )
    parser.add_argument(
        "-u",
        "--report-unknown",
        action="store_true",
        help="Show tracks with unknown rip status (neither Accurate nor Secure)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Verbose output",
    )
    parser.add_argument(
        "root",
        nargs="?",
        default=".",
        help="Root directory to scan",
    )
    return parser.parse_args()


def walk_flac_files(root: Path) -> Iterator[Path]:
    """
    Yield all .flac files under the given root directory,
    including the root itself, in sorted order.
    """
    root = Path(root)
    if not root.is_dir():
        raise NotADirectoryError(f"walk_flac_files: Root is not a directory: {root}")

    # Yield FLACs in the root directory first
    for flac in sorted(root.glob("*.flac")):
        yield flac

    # Then walk subdirectories in sorted order
    for directory in sorted(p for p in root.rglob("*") if p.is_dir()):
        for flac in sorted(directory.glob("*.flac")):
            yield flac


def parse_vorbis_comments(text: str) -> TrackMetadata:
    """
    Pass the VORBIS_COMMENT block text from metaflac
    and parse out the relevant metadata fields.
    """
    meta = TrackMetadata(None, None, None, None, None, None, None, None, None, None, None, None, None, None, 0)
    for line in text.splitlines():
        # Remove the "comment[x]: " prefix and just get the key=value part
        if "comment[" in line:
            entry = line[line.find(": ") + 2:]
        else:
            # skip this line, it is not a comment with key=value data
            continue
        key, _, value = entry.partition("=")
        key = key.lower()

        if key == "albumartist":
            meta.album_artist = value
        elif key == "artist":
            meta.artist = value
        elif key == "album":
            meta.album = value
        elif key == "date":
            meta.date = value
        elif key == "discnumber":
            meta.disc_number = int(value)
        elif key == "disctotal":
            meta.disc_total = int(value)
        elif key == "encoded by":
            meta.encoded_by = value
        elif key == "encoder":
            meta.encoder = value
        elif key == "genre":
            meta.genre = value
        elif key == "title":
            meta.track_name = value
        elif key == "tracknumber":
            meta.track_number = int(value)
        elif key == "tracktotal":
            meta.track_total = int(value)
        elif key == "accurateripresult":
            # Extract optional AccurateRip status
            if "accuraterip: inaccurate" in value.lower():
                meta.accuraterip = "inaccurate"
            elif "accuraterip: accurate" in value.lower():
                meta.accuraterip = "accurate"
            elif "accuraterip: not in database" in value.lower():
                meta.accuraterip = "not in database"
            # Extract optional Secure status
            if "secure: yes" in value.lower():
                meta.secure = "yes"
            elif "secure: no" in value.lower():
                meta.secure = "no"
            # Extract optional AccurateRip confidence value
            if "confidence" in value.lower():
                confidence_match = re.search(r'\(confidence\s+(\d+)\)', value, re.IGNORECASE)
                if confidence_match:
                    meta.ar_confidence = int(confidence_match.group(1))

    if meta.accuraterip == "not in database":
        logger.debug(f"parse_vorbis_comments: Track is not in AccurateRip database: {meta.album_artist} - {meta.album} - CD{meta.disc_number} - Track {meta.track_number}: {meta.track_name}")

    return meta


def test_parse_vorbis_comments(root: Path):
    for flac_file in walk_flac_files(root):
        try:
            # Run metaflac on each file
            result = subprocess.run(
                ["metaflac", "--list", "--block-type=VORBIS_COMMENT", str(flac_file)],
                capture_output=True,
                text=True,
                check=True
            )
            meta = parse_vorbis_comments(result.stdout)
        except subprocess.CalledProcessError as e:
            logger.error(f"test_parse_vorbis_comments: Error processing {flac_file}: {e}")


def short_track_status(meta: TrackMetadata) -> str:
    """
    Returns a string of two characters representing track AccurateRip and Secure status:
    - AccurateRip: "A" for accurate, "I" for inaccurate, "?" for unknown
    - Secure: "S" for secure, "N" for not secure, "?" for unknown
    """
    AR="?"
    if meta.accuraterip == "accurate":
        AR="A"
    elif meta.accuraterip == "inaccurate":
        AR="I"
    SR="?"
    if meta.secure == "yes":
        SR="S"
    elif meta.secure == "no":
        SR="N"
    return AR+SR


