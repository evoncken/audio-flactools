#!/usr/bin/env python3
# Purpose:
#   Parse FLAC file metadata for tracks ripped with dBpoweramp CD Ripper
#
#   Track metadata may contain AccurateRipResult in VORBIS_COMMENT block
#     AccurateRipResult can be "Accurate", "Inaccurate", or "Not in database"
#     This same comment line may contain "Secure: Yes" rip status
#     (depends on C2 pointers being enabled during ripping)
#
#   Quality assessment:
#     Track with AccurateRip status "Accurate" is considered 'perfect', regardless of "Secure" status.
#     Track with "Secure: Yes" status is 'good', even if AccurateRip status "Inaccurate" or "Not in database"
#     Track with neither Accurate nor Secure status is 'unknown' - need to verify by listening to rip

import argparse
import logging
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Iterator

logger = logging.getLogger(__name__)


@dataclass
class TrackMetadata:
    album_artist: str | None
    album: str | None
    artist: str | None
    date: str | None
    disc_number: int | 1
    disc_total: int | 1
    encoded_by: str | None
    encoder: str | None
    genre: str | None
    track_name: str | None
    track_number: int | None
    track_total: int | None
    accuraterip: str | None
    secure: str | None
    ar_confidence: int | 0


def parse_arguments() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Report AccurateRip / Secure status for FLAC tracks"
    )
    parser.add_argument(
        "-d",
        "--debug",
        action="store_true",
        help="Debugging output",
    )
    parser.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="Quiet output",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Verbose output",
    )
    parser.add_argument(
        "root",
        nargs="?",
        default=".",
        help="Root directory to scan",
    )
    return parser.parse_args()


def walk_flac_files(root: Path) -> Iterator[Path]:
    """
    Yield all .flac files under the given root directory,
    including the root itself, in sorted order.
    """
    root = Path(root)
    if not root.is_dir():
        raise NotADirectoryError(f"Root is not a directory: {root}")

    # Yield FLACs in the root directory first
    for flac in sorted(root.glob("*.flac")):
        yield flac

    # Then walk subdirectories in sorted order
    for directory in sorted(p for p in root.rglob("*") if p.is_dir()):
        for flac in sorted(directory.glob("*.flac")):
            yield flac


def parse_vorbis_comments(text: str) -> TrackMetadata:
    """
    Pass the VORBIS_COMMENT block text from metaflac
    and parse out the relevant metadata fields.
    """
    meta = TrackMetadata(None, None, None, None, None, None, None, None, None, None, None, None, None, None, 0)
    for line in text.splitlines():
        # Remove the "comment[x]: " prefix and just get the key=value part
        if "comment[" in line:
            entry = line[line.find(": ") + 2:]
        else:
            # skip this line, it is not a comment with key=value data
            continue
        key, _, value = entry.partition("=")
        key = key.lower()

        if key == "albumartist":
            meta.album_artist = value
        elif key == "artist":
            meta.artist = value
        elif key == "album":
            meta.album = value
        elif key == "date":
            meta.date = value
        elif key == "discnumber":
            meta.disc_number = int(value)
        elif key == "disctotal":
            meta.disc_total = int(value)
        elif key == "encoded by":
            meta.encoded_by = value
        elif key == "encoder":
            meta.encoder = value
        elif key == "genre":
            meta.genre = value
        elif key == "title":
            meta.track_name = value
        elif key == "tracknumber":
            meta.track_number = int(value)
        elif key == "tracktotal":
            meta.track_total = int(value)
        elif key == "accurateripresult":
            # Extract AccurateRip status and optional Secure status from the same comment line
            if "accuraterip: inaccurate" in value.lower():
                meta.accuraterip = "inaccurate"
            elif "accuraterip: accurate" in value.lower():
                meta.accuraterip = "accurate"
            elif "accuraterip: not in database" in value.lower():
                meta.accuraterip = "not in database"

            if "secure: yes" in value.lower():
                meta.secure = "yes"
            elif "secure: no" in value.lower():
                meta.secure = "no"

            if "confidence" in value.lower():
                confidence_match = re.search(r'\(confidence\s+(\d+)\)', value, re.IGNORECASE)
                if confidence_match:
                    meta.ar_confidence = int(confidence_match.group(1))

    if meta.accuraterip == "not in database":
        logger.debug(f"Track is not in AccurateRip database: {meta.album_artist} - {meta.album} - CD{meta.disc_number} - Track {meta.track_number}: {meta.track_name}")

    return meta


def test_parse_vorbis_comments(root: Path):
    for flac_file in walk_flac_files(root):
        try:
            # Run metaflac on each file
            result = subprocess.run(
                ["metaflac", "--list", "--block-type=VORBIS_COMMENT", str(flac_file)],
                capture_output=True,
                text=True,
                check=True
            )
            meta = parse_vorbis_comments(result.stdout)
        except subprocess.CalledProcessError as e:
            logger.error(f"Error processing {flac_file}: {e}")


def short_track_status(meta: TrackMetadata) -> str:
    # Determine AR and SR status symbols for logging
    AR="?"
    if meta.accuraterip == "accurate":
        AR="A"
    elif meta.accuraterip == "inaccurate":
        AR="I"
    SR="?"
    if meta.secure == "yes":
        SR="S"
    elif meta.secure == "no":
        SR="N"
    return AR+SR


def print_track_report(flac_file: Path, meta: TrackMetadata):
    # Determine track status based on AccurateRip and Secure metadata
    short_status=short_track_status(meta)
    if meta.accuraterip == "accurate" or meta.secure == "yes":
        print(f"[ OK ][{short_status}] {meta.album_artist} - {meta.album} (CD {meta.disc_number}/{meta.disc_total}) - {meta.track_number:2}/{meta.track_total:2}. {meta.track_name}")
    elif meta.accuraterip != "accurate" and meta.secure == "no":
        print(f"[FAIL][{short_status}] {meta.album_artist} - {meta.album} (CD {meta.disc_number}/{meta.disc_total}) - {meta.track_number:2}/{meta.track_total:2}. {meta.track_name}")
    else:
        print(f"[UNKN][{short_status}] {meta.album_artist} - {meta.album} (CD {meta.disc_number}/{meta.disc_total}) - {meta.track_number:2}/{meta.track_total:2}. {meta.track_name}")


def process_track_metadata(root: Path) -> dict:
    """
    Walk FLAC files under root, extract metadata and print per-track reports.
    Returns a nested dict collection[artist][album] -> list of (track_number, ar, sr).
    """
    total_tracks = 0
    collection: dict = {}

    if not root.is_dir():
        raise NotADirectoryError(f"Root is not a directory: {root}")

    for flac_file in walk_flac_files(root):
        try:
            logger.debug(f"Running metaflac on {flac_file}")
            result = subprocess.run(
                ["metaflac", "--list", "--block-type=VORBIS_COMMENT", str(flac_file)],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            logger.error(f"Error running metaflac on {flac_file}: {e}")
            continue

        meta = parse_vorbis_comments(result.stdout)
        
        # Record all track metadata in a nested dict: collection[artist][album]
        if meta.album_artist not in collection:
            collection[meta.album_artist]={}
        if meta.album not in collection[meta.album_artist]:
            collection[meta.album_artist][meta.album]=[]
        collection[meta.album_artist][meta.album].append(meta)

        logger.debug(meta)
        if args.verbose:
            print_track_report(flac_file, meta)

        total_tracks += 1

    logger.debug(f"Processed {total_tracks} tracks found under '{root}'")
    return collection


def get_accurate_albums(collection: dict) -> dict:
    """
    Analyze the artists dict to find albums with all tracks Accurate.
    Returns a 'collection' dict filtered to only contain Accurate albums.
    """
    accurate_collection = {}
    for artist, albums in collection.items():
        for album, tracks in albums.items():
            if all(track.accuraterip == "accurate" for track in tracks):
                if artist not in accurate_collection:
                    accurate_collection[artist] = {}
                accurate_collection[artist][album] = tracks
    return accurate_collection


def get_secure_albums(collection: dict) -> dict:
    """
    Analyze the artists dict to find albums with all tracks Secure.
    Returns a 'collection' dict filtered to only contain Secure albums.
    """
    secure_albums = {}
    for artist, albums in collection.items():
        for album, tracks in albums.items():
            if all(track.secure == "yes" for track in tracks):
                if artist not in secure_albums:
                    secure_albums[artist] = {}
                secure_albums[artist][album] = tracks
    return secure_albums


def get_bad_tracks(collection: dict) -> dict:
    """
    Analyze the artists dict to find albums with any bad tracks.
    Returns a nested dict of artists and albums with lists of bad tracks.
    """
    albums_with_errors = {}
    if collection:
        for artist, albums in collection.items():
            for album, tracks in albums.items():
                for track in tracks:
                    if track.accuraterip != "accurate" and track.secure != "yes":
                        if artist not in albums_with_errors:
                            albums_with_errors[artist] = {}
                        if album not in albums_with_errors[artist]:
                            albums_with_errors[artist][album] = []
                        albums_with_errors[artist][album].append(track)
    return albums_with_errors


def report_albums(collection: dict):
    """
    Print a report of artists and albums supplied as argument.
    
    Args:
        collection: A nested dict of artists and albums with track metadata.
    """
    if collection:
        for artist, albums in collection.items():
            print(f"{artist}")
            for album, tracks in albums.items():
                tracks = albums[album]
                if tracks[0].disc_total > 1:
                    print(f"    {album} (CD {tracks[0].disc_number}/{tracks[0].disc_total}, {len(tracks)} tracks)")
                else:
                    print(f"    {album} ({len(tracks)} tracks)")
            print("")
    else:
        logger.debug("No artists or albums found")


def report_bad_albums(collection: dict):
    """
    Print a formatted report of artists and albums with inaccurate or insecure tracks.
    
    Args:
        collection: A nested dict of artists and albums with track metadata.
    """
    trackcount = sum(len(tracks) for albums in collection.values() for tracks in albums.values())
    albums_with_errors = get_bad_tracks(collection)
    errorcount_artists = len(albums_with_errors.items())
    errorcount_albums = sum(len(tracks) for tracks in albums_with_errors.values())
    errorcount_tracks = sum(len(tracks) for albums in albums_with_errors.values() for tracks in albums.values())

    ansi_reset = ""
    ansi_red = ""
    ansi_green = ""
    ansi_unknown = ""
    if sys.stdout.isatty():
        ansi_reset = "\033[0m"
        ansi_red = "\033[31m"
        ansi_green = "\033[32m"
        ansi_unknown = "\033[33m"
    else:
        logger.debug(f"STDOUT is redirected, disable ANSI colors")

    if trackcount > 0:
        print(f"Summary of {errorcount_tracks} tracks (on {errorcount_albums} albums by {errorcount_artists} artists) that have issues:")
        print("-"*40)
        for artist, albums in albums_with_errors.items():
            print(f"{artist}")
            for album, tracks in albums.items():
                print(f"    {album}")
                for track in tracks:
                    short_status=short_track_status(track)
                    # Determine track rip status based on AccurateRip and Secure metadata
                    if track.accuraterip == "accurate" or track.secure == "yes":
                        ansi_color = ansi_green
                        track_status = "[ OK ]"
                    elif track.accuraterip != "accurate" and track.secure == "no":
                        ansi_color = ansi_red
                        track_status = "[FAIL]"
                    else:
                        ansi_color = ansi_unknown
                        track_status = "[UNKN]"
                    # ansi_color has to be entered directly into the f-string to work, it cannot be stored in a variable and then used in the f-string
                    disc_number = track.disc_number if track.disc_number is not None else "?"
                    print(f"      {ansi_color}{track_status}[{short_status}] CD{disc_number:>2} - {track.track_number:2}/{track.track_total:2}: {track.track_name}{ansi_reset}")
        print("")
    else:
        logger.warning("Skipping summary - no tracks found")


def print_summary_report(collection: dict):
    """
    Print statistics and summary report of tracks.
    
    Args:
        collection: A dict of artists with nested albums and tracks metadata.
    """
    # Statistics and summary report
    artistcount = len(collection)
    albumcount = sum(len(albums) for albums in collection.values())
    trackcount = sum(len(tracks) for albums in collection.values() for tracks in albums.values())
    logger.debug(f"Processed {trackcount} tracks on {albumcount} albums by {artistcount} artists\n")

    trackcount_accurate = sum(1 for albums in collection.values() for tracks in albums.values() for track in tracks if track.accuraterip == "accurate")
    trackcount_inaccurate_secure = sum(1 for albums in collection.values() for tracks in albums.values() for track in tracks if track.accuraterip == "inaccurate" and track.secure == "yes")
    trackcount_not_in_accurip = sum(1 for albums in collection.values() for tracks in albums.values() for track in tracks if track.accuraterip == "not in database")
    trackcount_not_in_accurip_secure = sum(1 for albums in collection.values() for tracks in albums.values() for track in tracks if track.accuraterip == "not in database" and track.secure == "yes")

    trackcount_good = trackcount_accurate + trackcount_inaccurate_secure + trackcount_not_in_accurip_secure

    if trackcount > 0:
        print("Processing summary:")
        print("-"*40)
        print(f"  {artistcount:6} artists")
        print(f"  {albumcount:6} albums")
        print(f"  {trackcount:6} tracks\n")
        print("AccurateRip and Secure status summary:")
        print("-"*40)
        print(f"  {trackcount_good:6} tracks out of {trackcount} ({trackcount_good/trackcount*100:.1f}%) are GOOD (Accurate or Secure rip)")
        print(f"         {trackcount_accurate:6} tracks out of {trackcount} ({trackcount_accurate/trackcount*100:.1f}%) are Accurate")
        print(f"         {trackcount_inaccurate_secure:6} tracks out of {trackcount} ({trackcount_inaccurate_secure/trackcount*100:.1f}%) are Secure (Inaccurate)")
        print(f"         {trackcount_not_in_accurip_secure:6} tracks out of {trackcount} ({trackcount_not_in_accurip_secure/trackcount*100:.1f}%) are Secure (Not in Database)\n")

        if trackcount - trackcount_good > 0:
            print(f"  {trackcount - trackcount_good:6} tracks out of {trackcount} ({(trackcount - trackcount_good)/trackcount*100:.1f}%) need verification (Inaccurate and not Secure)\n")
    else:
        logger.warning("Skipping summary - no tracks found")


def main():
    root_path = Path(args.root)
    if not root_path.is_dir():
        raise NotADirectoryError(f"Root is not a directory: {root_path}")

    logger.debug("Obtaining track metadata...")
    disc_collection = process_track_metadata(root_path)
    total_artist_count = len(disc_collection)
    total_album_count = sum(len(albums) for albums in disc_collection.values())
    print_summary_report(disc_collection)

    accurate_collection = get_accurate_albums(disc_collection)
    accurate_album_count = sum(len(albums) for albums in accurate_collection.values())
    print(f"Accurate Albums ({accurate_album_count} out of {total_album_count}):")
    print("-"*40)
    report_albums(accurate_collection)

    secure_collection = get_secure_albums(disc_collection)
    secure_album_count = sum(len(albums) for albums in secure_collection.values())
    print(f"Secure Albums ({secure_album_count} out of {total_album_count}):")
    print("-"*40)
    report_bad_albums(secure_collection)


if __name__ == "__main__":
    args = parse_arguments()
    level = logging.INFO
    if args.verbose:
        level = logging.INFO    # FIXME, redundant with default
    elif args.debug:
        level = logging.DEBUG
    logging.basicConfig(level=level, format='%(levelname)s: %(message)s')

    try:
        main()
    except KeyboardInterrupt as e:
        logger.info("\nInterrupted")
        sys.exit(130)
