def process_track_metadata(root: Path) -> dict:
    """
    Walk FLAC files under root, extract metadata and print per-track reports.
    Returns a collection dict: collection[artist][album] = list of TrackMetadata for each track on that album
    """
    total_tracks = 0
    collection: dict = {}

    if not root.is_dir():
        raise NotADirectoryError(f"process_track_metadata: '{root}' is not a directory")

    for flac_file in walk_flac_files(root):
        try:
            logger.debug(f"process_track_metadata: Running metaflac on {flac_file}")
            result = subprocess.run(
                ["metaflac", "--list", "--block-type=VORBIS_COMMENT", str(flac_file)],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            logger.error(f"process_track_metadata: Error running metaflac on {flac_file}: {e}")
            continue

        meta = parse_vorbis_comments(result.stdout)
        
        # Record all track metadata in a nested dict: collection[artist][album]
        if meta.album_artist not in collection:
            collection[meta.album_artist]={}
        if meta.album not in collection[meta.album_artist]:
            collection[meta.album_artist][meta.album]=[]
        collection[meta.album_artist][meta.album].append(meta)
        total_tracks += 1

    logger.debug(f"process_track_metadata: Processed {total_tracks} tracks found under path '{root}'")
    return collection


def get_good_discs(collection: dict) -> dict:
    """
    Analyze the collection dict to find discs with all tracks AR:"accurate" or Secure:"yes".
    Returns a collection dict only containing "Good" discs.
    """
    filtered_collection = {}
    if collection:
        for artist, discs in collection.items():
            for disc, tracks in discs.items():
                if all((track.accuraterip == "accurate" or track.secure == "yes") for track in tracks):
                    if artist not in filtered_collection:
                        filtered_collection[artist] = {}
                    filtered_collection[artist][disc] = tracks
    else:
        logger.debug("get_good_discs: No artists or albums in collection")
    disccount = sum(len(discs) for discs in filtered_collection.values())
    logger.debug("get_good_discs: Filtered collection has {disccount} discs")
    return filtered_collection


def get_warning_discs(collection: dict) -> dict:
    """
    Analyze the collection dict to find discs with any track Secure:"warn" and not AR:"accurate".
    Returns a collection dict only containing discs with Warnings. Recommend listening to verify.
    """
    filtered_collection = {}
    if collection:
        for artist, discs in collection.items():
            for disc, tracks in discs.items():
                if any((track.secure == "warn" and track.accuraterip != "accurate") for track in tracks):
                    if artist not in filtered_collection:
                        filtered_collection[artist] = {}
                    filtered_collection[artist][disc] = tracks
    else:
        logger.debug("get_warning_discs: No artists or albums in collection")
    disccount = sum(len(discs) for discs in filtered_collection.values())
    logger.debug("get_warning_discs: Filtered collection has {disccount} discs")
    return filtered_collection


def get_bad_discs(collection: dict) -> dict:
    """
    Analyze the collection dict to find discs with any track Secure:"no" and not Accurate:"yes".
    Returns a collection dict only containing "Good" discs.
    """
    filtered_collection = {}
    if collection:
        for artist, discs in collection.items():
            for disc, tracks in discs.items():
                if any((track.accuraterip != "accurate" and track.secure == "no") for track in tracks):
                    if artist not in filtered_collection:
                        filtered_collection[artist] = {}
                    filtered_collection[artist][disc] = tracks
    else:
        logger.debug("get_bad_discs: No artists or albums in collection")
    disccount = sum(len(discs) for discs in filtered_collection.values())
    logger.debug("get_bad_discs: Filtered collection has {disccount} discs")
    return filtered_collection


def get_accurate_discs(collection: dict) -> dict:
    """
    Analyze the collection dict to find discs with all tracks AR:Accurate.
    Returns a collection dict filtered to only contain AR:Accurate discs.
    """
    filtered_collection = {}
    if collection:
        for artist, discs in collection.items():
            for disc, tracks in discs.items():
                if all(track.accuraterip == "accurate" for track in tracks):
                    if artist not in filtered_collection:
                        filtered_collection[artist] = {}
                    filtered_collection[artist][disc] = tracks
    else:
        logger.debug("get_accurate_discs: No artists or albums in collection")
    disccount = sum(len(discs) for discs in filtered_collection.values())
    logger.debug("get_accurate_discs: Filtered collection has {disccount} discs")
    return filtered_collection


def get_secure_discs(collection: dict) -> dict:
    """
    Analyze the collection dict to find discs with all tracks Secure.
    Returns a collection dict filtered to only contain Secure discs.
    """
    filtered_collection = {}
    if collection:
        for artist, discs in collection.items():
            for disc, tracks in discs.items():
                if all(track.secure == "yes" for track in tracks):
                    if artist not in filtered_collection:
                        filtered_collection[artist] = {}
                    filtered_collection[artist][disc] = tracks
    else:
        logger.debug("get_secure_discs: No artists or albums in collection")
    disccount = sum(len(discs) for discs in filtered_collection.values())
    logger.debug("get_secure_discs: Filtered collection has {disccount} discs")
    return filtered_collection


def get_unknown_discs(collection: dict) -> dict:
    """
    Analyze the collection dict to find discs with any unknown tracks (not AR:Accurate, not Secure:yes/warn).
    Returns a collection dict filtered to only contain discs with unknown tracks.
    """
    filtered_collection = {}
    if collection:
        for artist, discs in collection.items():
            for disc, tracks in discs.items():
                for track in tracks:
                    if track.accuraterip != "accurate" and track.secure != "yes" and track.secure != "warn":
                        if artist not in filtered_collection:
                            filtered_collection[artist] = {}
                        filtered_collection[artist][disc] = tracks
    else:
        logger.debug("get_unknown_discs: No artists or albums in collection")
    disccount = sum(len(discs) for discs in filtered_collection.values())
    logger.debug("get_unknown_discs: Filtered collection has {disccount} discs")
    return filtered_collection


def print_report(collection: dict):
    """
    Print a report of artists and albums supplied as argument.
    
    Args:
        collection: A nested dict of artists and albums with track metadata.
    """

    ansi_reset = ""
    ansi_red = ""
    ansi_yellow = ""
    ansi_green = ""
    ansi_unknown = ""
    if sys.stdout.isatty():
        ansi_reset = "\033[0m"
        ansi_red = "\033[91m"
        ansi_yellow = "\033[93m"
        ansi_green = "\033[92m"
        ansi_unknown = "\033[95m"

    if collection:
        for artist, albums in collection.items():
            print(f"{artist}")
            for album, tracks in sorted(albums.items()):
                tracks = albums[album]
                if args.verbose:
                    print(f"    {album}")
                    for track in tracks:
                        short_status=short_track_status(track)
                        # Determine track rip status based on AccurateRip and Secure metadata
                        if track.accuraterip == "accurate" or track.secure == "yes":
                            ansi_color = ansi_green
                            track_status = "[ OK ]"
                        elif track.accuraterip != "accurate" and track.secure == "warn":
                            ansi_color = ansi_yellow
                            track_status = "[WARN]"
                        elif track.accuraterip != "accurate" and track.secure == "no":
                            ansi_color = ansi_red
                            track_status = "[FAIL]"
                        else:
                            ansi_color = ansi_unknown
                            track_status = "[UNKN]"
                        # ansi_color has to be entered directly into the f-string to work, it cannot be stored in a variable and then used in the f-string
                        disc_number = track.disc_number if track.disc_number is not None else "?"
                        print(f"      {ansi_color}{track_status}[{short_status}] CD{disc_number:>2} - {track.track_number:2}/{track.track_total:2}: {track.track_name}{ansi_reset}")
                else:
                    if tracks[0].disc_total == 1:
                        print(f"    {album} ({tracks[0].disc_total} CD, {len(tracks)} tracks)")
                    elif tracks[0].disc_total > 1:
                        print(f"    {album} ({tracks[0].disc_total} CDs, {len(tracks)} tracks)")
                    else:
                        print(f"    {album} (? CDs, {len(tracks)} tracks)")
            print("")
    else:
        logger.debug("report_albums: No artists or albums in collection")


def print_track_summary(collection: dict):
    """
    Print statistics and summary report of tracks.
    
    Args:
        collection: A dict of artists with nested albums and tracks metadata.
    """
    # Statistics and summary report
    artistcount = len(collection)
    disccount = sum(len(discs) for discs in collection.values())
    trackcount = sum(len(tracks) for discs in collection.values() for tracks in discs.values())
    logger.debug(f"print_track_summary: Processed {trackcount} tracks on {disccount} discs by {artistcount} artists\n")

    trackcount_accurate = sum(1 for discs in collection.values() for tracks in discs.values() for track in tracks if track.accuraterip == "accurate")
    trackcount_inaccurate_secure = sum(1 for discs in collection.values() for tracks in discs.values() for track in tracks if track.accuraterip == "inaccurate" and track.secure == "yes")
    trackcount_not_in_accurip = sum(1 for discs in collection.values() for tracks in discs.values() for track in tracks if track.accuraterip == "not in database")
    trackcount_not_in_accurip_secure = sum(1 for discs in collection.values() for tracks in discs.values() for track in tracks if track.accuraterip == "not in database" and track.secure == "yes")

    trackcount_good = trackcount_accurate + trackcount_inaccurate_secure + trackcount_not_in_accurip_secure

    if trackcount > 0:
        logger.debug(f"print_track_summary: {disccount} disc(s) by {artistcount} artist(s), totaling {trackcount} track(s)\n")
        print("Track status summary:")
        print("-"*40)
        print(f"  {trackcount_good:6} tracks out of {trackcount} ({trackcount_good/trackcount*100:.1f}%) are GOOD (AR:Accurate or Secure rip):")
        print(f"         {trackcount_accurate:6} tracks out of {trackcount} ({trackcount_accurate/trackcount*100:.1f}%) are AR:Accurate")
        print(f"         {trackcount_inaccurate_secure:6} tracks out of {trackcount} ({trackcount_inaccurate_secure/trackcount*100:.1f}%) are Secure (AR:Inaccurate)")
        print(f"         {trackcount_not_in_accurip_secure:6} tracks out of {trackcount} ({trackcount_not_in_accurip_secure/trackcount*100:.1f}%) are Secure (Not in Database)\n")
        if trackcount - trackcount_good > 0:
            print(f"  {trackcount - trackcount_good:6} tracks out of {trackcount} ({(trackcount - trackcount_good)/trackcount*100:.1f}%) need verification (AR:Inaccurate and not Secure)\n")
    else:
        logger.warning("print_track_summary: Skipping summary - no tracks found")


def print_disc_summary(collection: dict):
    """
    Print statistics and summary report of discs.
    
    Args:
        collection: A dict of artists with nested albums and tracks metadata.
    """
    artistcount = len(collection)
    disccount = sum(len(discs) for discs in collection.values())

    if disccount > 0:
        logger.debug("print_disc_summary: Generating disc summary")

        good_collection = get_good_discs(collection)
        disccount_good = sum(len(discs) for discs in good_collection.values())
        bad_collection = get_bad_discs(collection)
        disccount_bad = sum(len(discs) for discs in bad_collection.values())
        warning_collection = get_warning_discs(collection)
        disccount_warning = sum(len(discs) for discs in warning_collection.values())
        accurate_collection = get_accurate_discs(collection)
        disccount_accurate = sum(len(discs) for discs in accurate_collection.values())
        secure_collection = get_secure_discs(collection)
        disccount_secure = sum(len(discs) for discs in secure_collection.values())
        unknown_collection = get_unknown_discs(collection)
        disccount_unknown = sum(len(discs) for discs in unknown_collection.values())

        print(f"Processing summary: {disccount} disc(s) by {artistcount} artist(s)\n")
        print("Disc status summary:")
        print("-"*40)
        print(f"  {disccount_good:6} discs out of {disccount} ({disccount_good/disccount*100:.1f}%) are GOOD (AR:'accurate' or Secure:'yes'):")
        print(f"         {disccount_accurate:6} discs out of {disccount} ({disccount_accurate/disccount*100:.1f}%) are PERFECT (AR:'accurate')")
        print(f"         {disccount_secure:6} discs out of {disccount} ({disccount_secure/disccount*100:.1f}%) are OK (Secure:'yes')")
        print()
        print(f"         {disccount_warning:6} discs out of {disccount} ({disccount_warning/disccount*100:.1f}%) have Warnings (corrected read errors)")
        print(f"         {disccount_bad:6} discs out of {disccount} ({disccount_bad/disccount*100:.1f}%) are Bad (uncorrected read errors)")
        print(f"         {disccount_unknown:6} discs out of {disccount} ({disccount_unknown/disccount*100:.1f}%) are Unknown (not AR:Accurate and not Secure)\n")
    else:
        logger.warning("print_disc_summary: Skipping summary - no discs found")


def main():
    root_path = Path(args.root)
    if not root_path.is_dir():
        raise NotADirectoryError(f"Root is not a directory: {root_path}")

    print(f"Reading track metadata for all FLAC files under '{root_path}' ...")
    disc_collection = process_track_metadata(root_path)
    disc_count = sum(len(discs) for discs in disc_collection.values())
    artist_count = len(disc_collection)

    print_disc_summary(disc_collection)
    print_track_summary(disc_collection)

    if args.report_full:
        print(f"All {disc_count} albums by {artist_count} artists in collection:")
        print("-"*40)
        print_report(disc_collection)

    if args.report_accurate:
        # All tracks AR:Accurate - this is more strict than 'report_good', basically 'perfect'
        accurate_collection = get_accurate_discs(disc_collection)
        accurate_artist_count = len(accurate_collection)
        accurate_disc_count = sum(len(discs) for discs in accurate_collection.values())
        print(f"Discs with all tracks Accurate ({accurate_disc_count} out of {disc_count}, {accurate_artist_count} artists):")
        print("-"*40)
        print_report(accurate_collection)

    if args.report_secure:
        # This probably only applies to successfully ripped discs discs that are not in AccurateRip database
        secure_collection = get_secure_discs(disc_collection)
        secure_artist_count = len(secure_collection)
        secure_disc_count = sum(len(discs) for discs in secure_collection.values())
        print(f"Discs with all tracks Secure ({secure_disc_count} out of {disc_count}, {secure_artist_count} artists):")
        print("-"*40)
        print_report(secure_collection)

    if args.report_good:
        # All tracks AR:Accurate or Secure
        good_collection = get_good_discs(disc_collection)
        good_artist_count = len(good_collection)
        good_disc_count = sum(len(discs) for discs in good_collection.values())
        print(f"Good discs with all tracks Secure or Accurate ({good_disc_count} out of {disc_count}, {good_artist_count} artists):")
        print("-"*40)
        print_report(good_collection)

    if args.report_warning:
        warning_collection = get_warning_discs(disc_collection)
        warning_artist_count = len(warning_collection)
        warning_disc_count = sum(len(discs) for discs in warning_collection.values())
        print(f"Discs with one or more warnings in tracks ({warning_disc_count} out of {disc_count}):")
        print("-"*40)
        print_report(warning_collection)

    if args.report_bad:
        bad_collection = get_bad_discs(disc_collection)
        bad_artist_count = len(bad_collection)
        bad_disc_count = sum(len(discs) for discs in bad_collection.values())
        print(f"Discs with one or more bad tracks ({bad_disc_count} out of {disc_count}):")
        print("-"*40)
        print_report(bad_collection)


if __name__ == "__main__":
    args = parse_arguments()
    level = logging.WARNING
    if args.verbose:
        level = logging.INFO
    elif args.debug:
        level = logging.DEBUG
    logging.basicConfig(level=level, format='%(levelname)s: %(message)s')

    try:
        main()
    except KeyboardInterrupt as e:
        logger.info("\nInterrupted")
        sys.exit(130)
